# ============================================
# MANDOMOOD — Environment Variables
# Copy file này thành .env.local và điền vào
# ============================================

# MongoDB (Tạo tại mongodb.com/atlas - FREE)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/mandomood?retryWrites=true&w=majority

# NextAuth (Tạo secret: openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-this

# Google OAuth (Tạo tại console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI (Tao tai https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI fallback, tuy chon
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MandoMood

# ElevenLabs TTS (Optional — tao tai elevenlabs.io, upgrade audio quality)
# Neu khong co, app tu dong dung Web Speech API (zh-CN) lam fallback
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Voice IDs tot cho tieng Trung: 
#   EXAVITQu4vr4xnSDxMaL (Sarah - multilingual v2)
#   21m00Tcm4TlvDq8ikWAM (Rachel - multilingual)

# Stripe (Optional — Sprint 16, de sau)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Stripe Price IDs (tạo trong Stripe Dashboard -> Products)
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_xxxxx_monthly
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_xxxxx_yearly
NEXT_PUBLIC_STRIPE_LIFETIME_PRICE_ID=price_xxxxx_lifetime

# Web Push (VAPID) — tạo key pair: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
PUSH_ADMIN_SECRET=your-random-admin-secret
# Bí mật cho Vercel Cron gọi /api/push/due-reminder (nhắc nhở ngắt quãng SRS).
# Đặt cùng giá trị này vào "Cron Secret" trong Vercel project settings.
CRON_SECRET=your-random-cron-secret

# Admin (Feedback dashboard tại /admin/feedback)
ADMIN_SECRET=your-random-admin-secret-here

# Admin role — email được phép vào /admin/*
# Mặc định: ngothanhduy04@gmail.com (không cần set nếu chỉ dùng email này)
# Nhiều email: phân cách bằng dấu phẩy
ADMIN_EMAILS=ngothanhduy04@gmail.com
